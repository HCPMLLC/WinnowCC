DB_URL=postgresql+psycopg://resumematch:resumematch@localhost:5432/resumematch
REDIS_URL=redis://localhost:6379/0
# AUTH_SECRET is required - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET=
AUTH_COOKIE_NAME=rm_session
AUTH_TOKEN_EXPIRES_DAYS=7
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
JOB_SOURCES=remotive,themuse,greenhouse,lever,remoteok,adzuna,jooble,usajobs,jobicy,himalayas,manual,jsearch
GREENHOUSE_COMPANIES=
LEVER_COMPANIES=
MANUAL_JOBS_PATH=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=
RAPIDAPI_KEY=

# Telnyx SMS (optional — enables SMS OTP + job alerts)
# Set inbound message webhook in Telnyx portal to: https://<your-api-domain>/api/webhooks/telnyx/inbound
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=

# ── Admin Test Mode ────────────────────────────────────────────
# Comma-separated emails that bypass billing checks for testing.
ADMIN_TEST_EMAILS=
