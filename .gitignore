# Service account keys — never commit
github-actions-key.json

# Python
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Node / Next
**/node_modules/
**/.next/
**/dist/

# Environment / secrets
**/.env
**/.env.*
!**/.env.example

# Local uploads & data
services/api/data/uploads/
services/api/data/resumes/
services/api/data/recruiter_resumes/
services/api/data/*.sqlite*
**/*.log

# Temporary debug/check scripts
services/api/_check_profiles.py

# Script progress files
scripts/pipeline_upload_progress.json

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude IDE settings (may contain tokens in command history)
.claude/settings.local.json

# Session cookie files
cookies*.txt

# Temporary debug/export files
tmp_*.json
tmp_*.txt
nul
openapi*.json

# Coverage & Expo cache
.coverage
.expo/

# Log directory extras (json/txt not covered by *.log)
services/api/logs/*.json
services/api/logs/*.txt
