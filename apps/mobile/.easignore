# .easignore — exclude files from EAS build uploads
# Based on .gitignore plus additional build-irrelevant files

# dependencies (resolved on EAS build servers)
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# secrets
google-play-key.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# git
.git/

# docs and config not needed for builds
*.md
LICENSE
.vscode/
