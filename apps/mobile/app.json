{
  "expo": {
    "name": "Winnow — AI Job Matching",
    "slug": "winnow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "winnow",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3025"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.winnowcc.app",
      "buildNumber": "1",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "winnowcc.ai": {
              "NSExceptionAllowsInsecureHTTPLoads": false
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Winnow needs access to your photo library to upload resume documents and profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B3025"
      },
      "package": "ai.winnowcc.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "privacyUrl": "https://winnowcc.ai/privacy",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1B3025"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e478f6c7-06cd-4a45-abb2-100c25facf68"
      },
      "router": {}
    },
    "owner": "hcpmllc"
  }
}
